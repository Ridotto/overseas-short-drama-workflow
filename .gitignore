**/.DS_Store

# local session / scratch
.context/
.claude/hooks/.logs/
.local-archive/
tmp_*

# editor / system noise
*.swp
*.swo
*.tmp

# local env
.env
.env.*

# python
__pycache__/
*.pyc

# runtime inputs and generated drama projects
input/**
!input/
!input/.gitkeep
